# ===========================================
# VerbIA Agents - Environment Variables
# ===========================================
# Only VITE_* variables are exposed to the frontend.
# Sensitive API keys (N8N, WhatsApp, etc.) must NEVER
# be VITE_* — they go in Supabase Edge Function env vars
# or N8N credentials instead.
# ===========================================

# Supabase (public — protected by RLS)
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
